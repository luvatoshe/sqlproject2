-- Create table system_logs and sequence for id

create sequence system_logs_seq
start with 1
increment by 1
nocache
nocycle;

create table system_logs (log_id number primary key,
                          event_time  timestamp,
                          module_name varchar2(64),
                          user_id     number,
                          event_type  varchar2(20) constraint chk_event_type
                                      check (event_type in ('INFO', 'WARNING', 'ERROR', 'CRITICAL')),
                          message     clob,
                          ip_adress   varchar2(64)
)

-- Create partition by event_type and 

partition by range (event_time)
interval (numtoyminterval(1, 'MONTH'))
subpartition by list (event_type)
subpartition template (
    subpartition sp_info values ('INFO'),
    subpartition sp_warning values ('WARNING'),
    subpartition sp_error values ('ERROR'),
    subpartition sp_critical values ('CRITICAL'),
    subpartition sp_other values ('default')
)
(
partition p_initial values less than (timestamp '2026-07-01 00:00:00')
);