-- Archivate procedure

create or replace procedure archive_table (p_month varchar2)
is
    v_partition_name varchar2(100);
    v_exists     number;
    v_sql        varchar2(4000);
    v_start_date date;
    v_end_date   date;
    v_is_old     boolean := false;
    v_count      number;
begin
    -- Modifying p_month date
    v_start_date := to_date(p_month || '-01', 'YYYY-MM-DD');
    v_end_date := add_months(v_start_date, 1);
    v_partition_name := 'P_' || replace(p_month, '-', '_');
    
    -- Check if the section exists
    select count(*)
    into v_exists
    from user_tab_partitions
    where table_name = 'SYSTEM_LOGS'
        and partition_name = upper(v_partition_name);
        
    -- Error if not exists
    if v_exists = 0 then
            raise_application_error(-20001, 'Section '  ||v_partition_name|| ' not found');
    end if;
    
    -- If records in partition exist more than 2 years?
    select count(*)
    into v_count
    from system_logs partition (upper(v_partition_name))
    where event_time < add_months(sysdate, -24);
    
    if v_count > 0 then
        v_is_old := true;
        dbms_output.put_line('Found ' ||v_count|| ' records older than 2 years');
    else 
        dbms_output.put_line('Records older than 2 years not found');
        return;
    end if;
    
    -- Procedure if exists
    if v_is_old then
        -- Clone old data to archive table
        v_sql := 'insert into system_logs_archive (log_id, 
                                                   event_time, 
                                                   module_name, 
                                                   user_id, 
                                                   event_type, 
                                                   message, 
                                                   ip_adress)
                 select log_id, 
                        event_time, 
                        module_name, 
                        user_id, 
                        event_type, 
                        message, 
                        ip_adress
                 from system_logs partition(' ||upper(v_partition_name)|| ')
                 where event_time < add_months(sysdate, -24)';
        execute immediate v_sql;
        dbms_output.put_line('Archived ' || sql%rowcount || ' records');
        
        -- Delete old data from main table                                           
        v_sql := 'delete from system_logs partition (' ||upper(v_partition_name)|| ')
                  where event_time < add_months(sysdate, -24)';
        execute immediate v_sql;
        dbms_output.put_line('Deleted ' || sql%rowcount || ' records from table system_logs');
        
        -- Drop partition if its blank, else return the amount of left strings
        select count(*)
        into v_count
        from system_logs partition (upper(v_partition_name));
        
        if v_count = 0 then
            v_sql :=  'alter table system_logs drop partition' || upper(v_partition_name);
            execute immediate v_sql;
            dbms_output.put_line('Section ' || upper(v_partition_name) || ' deleted');
        else
            dbms_output.put_line('In section' || upper(v_partition_name) || ' still '|| v_count ||' records left');
        end if;
        commit;
    end if;
    
exception
    when others then
        rollback;
        dbms_output.put_line('Error: ' || sqlerrm);
        raise;
end archive_table;
/

